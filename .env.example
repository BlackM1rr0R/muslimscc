# ═══════════════════════════════════════════════════════
# FIREBASE CONFIG
# ═══════════════════════════════════════════════════════
# 1. .env adı ilə bu faylı kopyalayın (.env.example → .env)
# 2. Firebase Console-dan dəyərləri yapışdırın
# 3. Vite *yalnız* VITE_ prefiksli env-ləri istifadə edir

VITE_FIREBASE_API_KEY=YOUR_API_KEY_HERE
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:abc123def456

# ═══════════════════════════════════════════════════════
# PUSH NOTIFICATIONS (FCM)
# ═══════════════════════════════════════════════════════
# Firebase Console > Project Settings > Cloud Messaging > Web Push certificates
# "Generate key pair" düyməsini basın → açarı bura yapışdırın
VITE_FCM_VAPID_KEY=YOUR_VAPID_KEY_HERE

# ═══════════════════════════════════════════════════════
# BACKEND API URL (Vercel-də deploy olunmuş)
# ═══════════════════════════════════════════════════════
# Lokal test: http://localhost:3000
# Production: https://your-vercel-project.vercel.app
VITE_API_URL=https://your-vercel-project.vercel.app

# Admin paneldən bildiriş göndərmək üçün token
# (Vercel-də ADMIN_TOKEN ilə eyni dəyər olmalıdır)
VITE_ADMIN_TOKEN=your-secret-admin-token-here
